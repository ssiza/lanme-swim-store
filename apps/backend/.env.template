STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
# Railway: use the Redis plugin URL. Append ?family=0 if IPv6 connection fails.
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
# Database — Neon in production; local Postgres for development
# Neon: use pooled URL (host contains -pooler) with sslmode=require
DATABASE_URL=
DB_NAME=medusa-backend

# Public backend URL (optional — used by local file provider for upload URLs; defaults to http://localhost:9000)
MEDUSA_BACKEND_URL=http://localhost:9000

# Max admin upload size in MB (product media + hero widget). Default: 10
MEDUSA_MAX_UPLOAD_FILE_SIZE_MB=10

# Stripe (optional — provider registers only when STRIPE_API_KEY is set)
# Secret key from Stripe Dashboard → Developers → API keys (use sk_test_... in development)
STRIPE_API_KEY=
# Webhook signing secret from Stripe Dashboard or `stripe listen` (whsec_...)
# Required for production and for async flows (3DS, redirects). Optional for basic local card testing.
STRIPE_WEBHOOK_SECRET=

# S3-compatible file storage (optional — all five required vars must be set to switch from local storage)
# Public base URL for uploaded files (must match NEXT_PUBLIC_S3_PUBLIC_URL on the storefront)
# AWS example: https://your-bucket.s3.us-east-1.amazonaws.com
# Modern AWS buckets use bucket policies for public reads — ACLs are not used by this project.
S3_FILE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET=
# Required for Cloudflare R2, DigitalOcean Spaces, MinIO, etc.
S3_ENDPOINT=
# Set to true for path-style endpoints (common for MinIO and some S3-compatible providers)
S3_FORCE_PATH_STYLE=false

# Resend transactional email (optional — provider registers only when RESEND_API_KEY is set)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Lanmè Swim
RESEND_REPLY_TO=
# Optional: send all outbound email to this address during development
RESEND_DEV_REDIRECT=

# Storefront URL for links in customer emails (verification, password reset, orders)
STOREFRONT_URL=http://localhost:8000
# Shared secret for on-demand storefront cache revalidation (must match REVALIDATE_SECRET on storefront)
STOREFRONT_REVALIDATE_SECRET=
# Optional: default region segment in storefront links (matches storefront NEXT_PUBLIC_DEFAULT_REGION)
STORE_DEFAULT_REGION=us
