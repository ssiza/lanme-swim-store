# Publishable API key for the Lanme Swim backend. Required for the storefront to function.
# Learn how to create a publishable key: https://docs.medusajs.com/v2/resources/storefront-development/publishable-api-keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# URL of the Lanme Swim backend API server
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Default region code to use for the storefront
NEXT_PUBLIC_DEFAULT_REGION=us

# Base URL of the storefront (used for generating absolute URLs)
NEXT_PUBLIC_BASE_URL=https://localhost:8000

# Stripe publishable key (pk_test_... or pk_live_...) — required when Stripe is enabled on a region
NEXT_PUBLIC_STRIPE_KEY=

# Public URL for uploaded files in production (must match backend S3_FILE_URL)
NEXT_PUBLIC_S3_PUBLIC_URL=

# Lanme Swim Cloud S3 bucket hostname (optional, legacy Lanme Swim Cloud deployments)
MEDUSA_CLOUD_S3_HOSTNAME=

# Lanme Swim Cloud S3 bucket path (optional, legacy Lanme Swim Cloud deployments)
MEDUSA_CLOUD_S3_PATHNAME=

# Optional: shared secret for on-demand cache revalidation from the Lanme Swim backend
# Must match STOREFRONT_REVALIDATE_SECRET on the backend
REVALIDATE_SECRET=

